node_modules
dist
dist-ssr
*.local
.vite
.DS_Store
*.log

# editors
.vscode/*
!.vscode/extensions.json
.idea

# tauri
src-tauri/target
src-tauri/gen

# machine-specific cargo linker config (hardcoded MSVC path — per-machine)
.cargo/config.toml

# convex
.convex

# design bundle (kept locally as reference, not versioned)
_design_extracted
_design_package.tar

# TS incremental build cache
*.tsbuildinfo

# remember plugin — local session memory state (logs, tmp, pids); not source
.remember/

# playwright MCP output + smoke-test screenshots
.playwright-mcp/
smoke-*.png

# Claude Code project instructions — kept local, not versioned
CLAUDE.md

# design handoff archive — extracted to docs/design-kit/, the zip stays local
Shugu_Dev.zip

# Claude Code worktrees + plugin state (local tooling, per-developer)
.claude/

# pcc plugin state (local memory snapshots)
.pcc/

# Tauri icon auto-backup folders (created by icon regen scripts; the live
# src-tauri/icons/ directory is what matters)
src-tauri/icons.backup-*/

# Sidecar binaries — fetched per-machine via scripts/fetch-llama-binary.ps1,
# never committed (they are large, target-triple-specific, and version-
# bound). The directory itself, its README.md and checksum.txt ARE
# committed; only the actual binary artefacts are excluded.
src-tauri/binaries/*.exe
src-tauri/binaries/*.dll
src-tauri/binaries/runtime/*.dll
src-tauri/binaries/runtime/*.so
src-tauri/binaries/runtime/*.dylib
src-tauri/binaries/llama-server-*
